{
    "extends": "../tsconfig.base.json",
    "compilerOptions": {
        "outDir": "./dist",
        "module": "esnext",
        "moduleResolution": "bundler",
        "target": "es2022",
        "types": [
            "node"
        ],
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "declaration": false,
        "composite": false
    },
    "include": [
        "*.ts"
    ]
}